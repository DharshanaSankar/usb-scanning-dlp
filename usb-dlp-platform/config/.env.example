# =============================================================================
# Secure USB Monitoring and Data Exfiltration Prevention System - Phase 1
# Environment Configuration Template
# -----------------------------------------------------------------------------
# Copy this file to ".env" in the project root and adjust values as needed.
# NEVER commit a populated ".env" file to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
APP_ENV=development
APP_NAME=Secure USB DLP System
APP_VERSION=1.0.0-phase1

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Path is resolved relative to the project root unless absolute.
DB_PATH=database/usb_dlp.db
DB_TIMEOUT_SECONDS=30

# ---------------------------------------------------------------------------
# Agent / Monitoring
# ---------------------------------------------------------------------------
# Polling interval (seconds) used by the Windows fallback watcher and
# periodic housekeeping tasks.
POLL_INTERVAL_SECONDS=2

# Root mount path watched on Linux for newly mounted removable media.
LINUX_MEDIA_ROOT=/media

# Comma-separated list of mount root prefixes considered "removable" on
# Windows (drive letters are discovered dynamically via psutil, this is
# only used as a sanity filter).
WINDOWS_REMOVABLE_LABEL=Removable

# ---------------------------------------------------------------------------
# File Scanning
# ---------------------------------------------------------------------------
# Comma-separated list of file extensions (without dot) eligible for content
# scanning by the Sensitive Data Detection Engine.
SCAN_EXTENSIONS=txt,csv,log,json,xml

# Maximum file size (in MB) that will be read into memory for scanning.
# Larger files are still logged but only flagged via the "large file" risk
# rule, not content-inspected, to avoid excessive memory usage.
MAX_SCAN_SIZE_MB=50

# Chunk size (bytes) used while streaming large files for hashing/size checks.
FILE_READ_CHUNK_SIZE=65536

# ---------------------------------------------------------------------------
# Risk Scoring Thresholds
# ---------------------------------------------------------------------------
RISK_LOW_MAX=30
RISK_MEDIUM_MAX=60
# Anything above RISK_MEDIUM_MAX is HIGH

# ---------------------------------------------------------------------------
# Policy Engine
# ---------------------------------------------------------------------------
# Transfers with a risk score strictly greater than this value are blocked.
POLICY_BLOCK_THRESHOLD=60

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=usb_dlp_agent.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5

# ---------------------------------------------------------------------------
# Dashboard
# ---------------------------------------------------------------------------
DASHBOARD_REFRESH_SECONDS=5
DASHBOARD_PAGE_TITLE=Secure USB DLP Dashboard
